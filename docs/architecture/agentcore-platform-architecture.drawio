          <mxGeometry y="2" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="lg-7-desc" parent="lg-7" value="&lt;div&gt;&lt;b&gt;Agent Capabilities&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;-&lt;/font&gt; &lt;/b&gt;Inside the AgentCore platform the Runtime orchestrates Memory for context&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;-&lt;/font&gt; &lt;/b&gt;plus the Gateway (MCP tool Lambdas), Code Interpreter and Browser as tools&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" vertex="1">
          <mxGeometry x="52" y="0" width="568" height="78" as="geometry" />
