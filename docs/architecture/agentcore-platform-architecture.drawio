          <mxGeometry y="2" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="lg-6-desc" parent="lg-6" value="&lt;div&gt;&lt;b&gt;Model Inference&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;-&lt;/font&gt; &lt;/b&gt;Runtime agent loop calls Amazon Bedrock (Claude) for generation&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;-&lt;/font&gt; &lt;/b&gt;Responses stream back as SSE through App API to the SPA&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" vertex="1">
          <mxGeometry x="52" y="0" width="568" height="78" as="geometry" />
