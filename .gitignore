# Re-include scripts/build/ — that directory holds the content-hash-aware
# Docker build pipeline (compute-content-hash.sh, build-and-push-if-changed.sh,
# build-all-images.sh), which is source code, not a build artifact. The
# unqualified `build/` rules above otherwise match it.
!scripts/build/
!scripts/build/**

