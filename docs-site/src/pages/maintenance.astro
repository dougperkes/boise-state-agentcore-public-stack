---
// Standalone, full-screen maintenance page.
//
// This lives in `src/pages/` (NOT `src/content/docs/`), so it is deliberately
// outside the Starlight content collection: it never appears in the sidebar or
// any autogenerated nav, and it renders WITHOUT Starlight's chrome (no header,
// sidebar, or table of contents). It is reachable only by navigating directly
// to `/<base>/maintenance`.
//
// Route this page in front of users when the platform is briefly offline for a
// migration. The look mirrors the docs / SPA house style — Boise State brand
// blue (#0033a0), frosted glass, a graph-paper grid, and the drifting
// "lava-lamp" blob field — but the markup and styles are fully self-contained
// so the page renders correctly even if nothing else on the site loads.
const base = import.meta.env.BASE_URL;
const fontHref =
	'https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700;12..96,800&family=Inter:wght@400;450;500;600&family=JetBrains+Mono:wght@400;500&display=swap';
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<!-- A maintenance splash should never be indexed. -->
		<meta name="robots" content="noindex, nofollow" />
		<title>We'll be right back · AgentCore Public Stack</title>
		<link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="stylesheet" href={fontHref} />
	</head>
	<body>
		<!-- Decorative backdrop: lava-lamp blob field + graph-paper grid. -->
		<div class="lava-backdrop" aria-hidden="true">
			<div class="lava-field">
				<span class="lava-blob lava-blob--a"></span>
				<span class="lava-blob lava-blob--b"></span>
				<span class="lava-blob lava-blob--c"></span>
				<span class="lava-blob lava-blob--d"></span>
				<span class="lava-blob lava-blob--e"></span>
				<span class="lava-blob lava-blob--f"></span>
			</div>
			<div class="lava-grid"></div>
		</div>

		<main class="shell">
			<section class="panel" role="status" aria-live="polite">
				<span class="mark" aria-hidden="true">
					<svg viewBox="0 0 128 128" xmlns="http://www.w3.org/2000/svg">
						<path
							fill-rule="evenodd"
							d="M81 36 64 0 47 36l-1 2-9-10a6 6 0 0 0-9 9l10 10h-2L0 64l36 17h2L28 91a6 6 0 1 0 9 9l9-10 1 2 17 36 17-36v-2l9 10a6 6 0 1 0 9-9l-9-9 2-1 36-17-36-17-2-1 9-9a6 6 0 1 0-9-9l-9 10v-2Zm-17 2-2 5c-4 8-11 15-19 19l-5 2 5 2c8 4 15 11 19 19l2 5 2-5c4-8 11-15 19-19l5-2-5-2c-8-4-15-11-19-19l-2-5Z"
							clip-rule="evenodd"></path>
						<path
							d="M118 19a6 6 0 0 0-9-9l-3 3a6 6 0 1 0 9 9l3-3Zm-96 4c-2 2-6 2-9 0l-3-3a6 6 0 1 1 9-9l3 3c3 2 3 6 0 9Zm0 82c-2-2-6-2-9 0l-3 3a6 6 0 1 0 9 9l3-3c3-2 3-6 0-9Zm96 4a6 6 0 0 1-9 9l-3-3a6 6 0 1 1 9-9l3 3Z"
						></path>
					</svg>
				</span>

				<span class="kicker">Scheduled maintenance</span>

				<h1>We&rsquo;ll be right back</h1>

				<p class="lede">
					AgentCore Public Stack is briefly offline while we run a database
					migration. Nothing is required on your end &mdash; the platform will
					return on its own shortly.
				</p>

				<div class="progress" aria-hidden="true"><span></span></div>

				<p class="signoff">Thanks for your patience — the Boise State AI team.</p>
			</section>
		</main>

		<style>
			/* ---- Brand palette (derived from #0033a0, matching the docs theme) ---- */
			:root {
				--brand: #0033a0;
				--brand-300: oklch(from #0033a0 calc(l + 0.2) c h);
				--brand-400: oklch(from #0033a0 calc(l + 0.1) c h);
				--brand-500: #0033a0;
				--brand-600: oklch(from #0033a0 calc(l - 0.08) c h);
				--brand-700: oklch(from #0033a0 calc(l - 0.14) c h);
				--brand-800: oklch(from #0033a0 calc(l - 0.2) c h);
				--brand-orange: #d64309;

				--ink: hsl(210 40% 96%);
				--ink-dim: hsl(214 22% 72%);
				--bg: hsl(222 44% 5.5%);

				--font-body: 'Inter', ui-sans-serif, system-ui, -apple-system, 'Segoe UI',
					Roboto, sans-serif;
				--font-display: 'Bricolage Grotesque', var(--font-body);

				color-scheme: dark;
			}

			* {
				box-sizing: border-box;
			}

			html,
			body {
				margin: 0;
				min-height: 100%;
			}

			body {
				min-height: 100dvh;
				background: var(--bg);
				color: var(--ink);
				font-family: var(--font-body);
				-webkit-font-smoothing: antialiased;
				text-rendering: optimizeLegibility;
				overflow: hidden;
			}

			/* ===================================================================
			   Decorative backdrop — fixed lava-lamp blobs + graph-paper grid
			   =================================================================== */
			.lava-backdrop {
				position: fixed;
				inset: 0;
				z-index: 0;
				overflow: hidden;
				pointer-events: none;
				background:
					radial-gradient(
						125% 90% at 100% 0%,
						color-mix(in oklab, var(--brand-400) 24%, transparent),
						transparent 55%
					),
					radial-gradient(
						115% 85% at 0% 100%,
						color-mix(in oklab, var(--brand-700) 22%, transparent),
						transparent 55%
					);
			}

			.lava-field {
				position: absolute;
				inset: 0;
				overflow: hidden;
			}

			.lava-blob {
				position: absolute;
				display: block;
				will-change: transform, border-radius;
				border-radius: 58% 42% 60% 40% / 50% 55% 45% 50%;
			}

			.lava-blob--a {
				width: 70vw;
				height: 86vw;
				max-width: 880px;
				max-height: 1080px;
				bottom: -38vw;
				left: -18vw;
				filter: blur(110px);
				opacity: 0.4;
				background: radial-gradient(
					circle at 35% 35%,
					var(--brand-400),
					var(--brand-700) 60%,
					transparent 78%
				);
				animation:
					lava-rise-a 52s ease-in-out infinite alternate,
					lava-morph-a 28s ease-in-out infinite alternate;
			}

			.lava-blob--b {
				width: 62vw;
				height: 76vw;
				max-width: 800px;
				max-height: 960px;
				top: -34vw;
				right: -20vw;
				filter: blur(100px);
				opacity: 0.36;
				background: radial-gradient(
					circle at 65% 65%,
					var(--brand-500),
					var(--brand-800) 65%,
					transparent 82%
				);
				animation:
					lava-rise-b 60s ease-in-out infinite alternate,
					lava-morph-b 32s ease-in-out infinite alternate;
			}

			.lava-blob--c {
				width: 32vw;
				height: 40vw;
				max-width: 420px;
				max-height: 520px;
				top: 24%;
				left: 44%;
				filter: blur(60px);
				opacity: 0.5;
				background: radial-gradient(
					circle,
					color-mix(in oklab, var(--brand-300) 78%, white),
					transparent 72%
				);
				animation:
					lava-rise-c 30s ease-in-out infinite alternate,
					lava-morph-c 18s ease-in-out infinite alternate;
			}

			.lava-blob--d {
				width: 28vw;
				height: 36vw;
				max-width: 360px;
				max-height: 460px;
				bottom: -12vw;
				right: 16vw;
				filter: blur(55px);
				opacity: 0.55;
				background: radial-gradient(
					circle at 50% 50%,
					var(--brand-300),
					var(--brand-500) 60%,
					transparent 80%
				);
				animation:
					lava-rise-d 26s ease-in-out infinite alternate,
					lava-morph-a 16s ease-in-out infinite alternate -3s;
			}

			.lava-blob--e {
				width: 16vw;
				height: 22vw;
				max-width: 220px;
				max-height: 300px;
				top: -6vw;
				left: 30vw;
				filter: blur(32px);
				opacity: 0.6;
				background: radial-gradient(
					circle at 50% 50%,
					var(--brand-400),
					var(--brand-700) 65%,
					transparent 82%
				);
				animation:
					lava-rise-e 14s ease-in-out infinite alternate,
					lava-morph-b 11s ease-in-out infinite alternate -5s;
			}

			.lava-blob--f {
				width: 12vw;
				height: 16vw;
				max-width: 160px;
				max-height: 220px;
				bottom: -4vw;
				left: 12vw;
				filter: blur(26px);
				opacity: 0.65;
				background: radial-gradient(
					circle at 45% 45%,
					var(--brand-300),
					var(--brand-600) 65%,
					transparent 84%
				);
				animation:
					lava-rise-f 11s ease-in-out infinite alternate,
					lava-morph-c 9s ease-in-out infinite alternate -2s;
			}

			.lava-grid {
				position: absolute;
				inset: 0;
				background-image:
					linear-gradient(
						to right,
						color-mix(in oklab, var(--brand-300) 9%, transparent) 1px,
						transparent 1px
					),
					linear-gradient(
						to bottom,
						color-mix(in oklab, var(--brand-300) 9%, transparent) 1px,
						transparent 1px
					);
				background-size: 56px 56px;
				mask-image: radial-gradient(
					ellipse 80% 72% at 50% 42%,
					black 18%,
					transparent 80%
				);
				-webkit-mask-image: radial-gradient(
					ellipse 80% 72% at 50% 42%,
					black 18%,
					transparent 80%
				);
				opacity: 0.7;
			}

			/* ---- Blob trajectories + surface morph (lifted from the docs theme) ---- */
			@keyframes lava-rise-a {
				0% { transform: translate3d(0, 0, 0) scale(1, 1) rotate(0deg); }
				50% { transform: translate3d(2vw, -12vh, 0) scale(1.04, 0.96) rotate(4deg); }
				100% { transform: translate3d(-1vw, -22vh, 0) scale(0.97, 1.05) rotate(-3deg); }
			}
			@keyframes lava-rise-b {
				0% { transform: translate3d(0, 0, 0) scale(1, 1) rotate(0deg); }
				50% { transform: translate3d(-2vw, 10vh, 0) scale(0.96, 1.05) rotate(-4deg); }
				100% { transform: translate3d(1vw, 20vh, 0) scale(1.05, 0.96) rotate(3deg); }
			}
			@keyframes lava-rise-c {
				0% { transform: translate3d(0, 0, 0) scale(1, 1) rotate(0deg); }
				50% { transform: translate3d(-5vw, -25vh, 0) scale(1.1, 0.94) rotate(-10deg); }
				100% { transform: translate3d(4vw, -50vh, 0) scale(0.92, 1.1) rotate(8deg); }
			}
			@keyframes lava-rise-d {
				0% { transform: translate3d(0, 0, 0) scale(1, 1) rotate(0deg); }
				50% { transform: translate3d(6vw, -35vh, 0) scale(1.05, 0.95) rotate(12deg); }
				100% { transform: translate3d(-3vw, -68vh, 0) scale(0.92, 1.08) rotate(-7deg); }
			}
			@keyframes lava-rise-e {
				0% { transform: translate3d(0, 0, 0) scale(1, 1) rotate(0deg); }
				50% { transform: translate3d(8vw, 55vh, 0) scale(0.88, 1.14) rotate(-18deg); }
				100% { transform: translate3d(-6vw, 100vh, 0) scale(1.16, 0.86) rotate(14deg); }
			}
			@keyframes lava-rise-f {
				0% { transform: translate3d(0, 0, 0) scale(1, 1) rotate(0deg); }
				50% { transform: translate3d(-9vw, -55vh, 0) scale(1.18, 0.84) rotate(20deg); }
				100% { transform: translate3d(7vw, -105vh, 0) scale(0.85, 1.18) rotate(-16deg); }
			}
			@keyframes lava-morph-a {
				0% { border-radius: 58% 42% 60% 40% / 50% 55% 45% 50%; }
				50% { border-radius: 42% 58% 38% 62% / 60% 40% 60% 40%; }
				100% { border-radius: 50% 50% 65% 35% / 45% 55% 50% 50%; }
			}
			@keyframes lava-morph-b {
				0% { border-radius: 50% 50% 40% 60% / 55% 45% 55% 45%; }
				50% { border-radius: 65% 35% 55% 45% / 40% 60% 40% 60%; }
				100% { border-radius: 38% 62% 50% 50% / 60% 50% 50% 40%; }
			}
			@keyframes lava-morph-c {
				0% { border-radius: 60% 40% 50% 50% / 45% 60% 40% 55%; }
				50% { border-radius: 40% 60% 65% 35% / 55% 40% 60% 45%; }
				100% { border-radius: 55% 45% 38% 62% / 50% 55% 45% 50%; }
			}

			/* ===================================================================
			   Centered frosted-glass panel
			   =================================================================== */
			.shell {
				position: relative;
				z-index: 1;
				min-height: 100dvh;
				display: grid;
				place-items: center;
				padding: clamp(1.25rem, 4vw, 3rem);
			}

			.panel {
				width: min(40rem, 100%);
				display: flex;
				flex-direction: column;
				align-items: center;
				text-align: center;
				gap: 1.15rem;
				padding: clamp(2rem, 5vw, 3.5rem);
				border-radius: 1.5rem;
				border: 1px solid color-mix(in oklab, var(--brand) 26%, transparent);
				background: color-mix(in oklab, var(--bg) 52%, transparent);
				-webkit-backdrop-filter: blur(22px) saturate(150%);
				backdrop-filter: blur(22px) saturate(150%);
				box-shadow:
					0 1px 0 0 color-mix(in oklab, white 9%, transparent) inset,
					0 40px 90px -40px color-mix(in oklab, var(--brand-800) 90%, transparent);
				animation: panel-in 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
			}

			@keyframes panel-in {
				from {
					opacity: 0;
					transform: translateY(14px) scale(0.98);
				}
				to {
					opacity: 1;
					transform: none;
				}
			}

			/* Brand mark — frosted chip with the compass-star glyph, gently floating */
			.mark {
				display: grid;
				place-items: center;
				width: 4.5rem;
				height: 4.5rem;
				border-radius: 1.1rem;
				border: 1px solid color-mix(in oklab, var(--brand) 40%, transparent);
				background: color-mix(in oklab, var(--brand) 20%, transparent);
				box-shadow: 0 18px 40px -22px color-mix(in oklab, var(--brand) 85%, transparent);
				animation: mark-float 7s ease-in-out infinite alternate;
			}

			.mark svg {
				width: 2.35rem;
				height: 2.35rem;
			}

			.mark svg path {
				fill: var(--ink);
			}

			@keyframes mark-float {
				0% { transform: translateY(0) rotate(-3deg); }
				100% { transform: translateY(-8px) rotate(3deg); }
			}

			/* Eyebrow pill with a pulsing Bronco-orange status orb */
			.kicker {
				display: inline-flex;
				align-items: center;
				gap: 0.55rem;
				padding: 0.35rem 0.9rem;
				font-size: 0.72rem;
				font-weight: 600;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: hsl(214 30% 84%);
				background: color-mix(in oklab, var(--brand) 16%, transparent);
				border: 1px solid color-mix(in oklab, var(--brand) 34%, transparent);
				border-radius: 999px;
				-webkit-backdrop-filter: blur(10px);
				backdrop-filter: blur(10px);
			}

			.kicker::before {
				content: '';
				width: 0.5rem;
				height: 0.5rem;
				border-radius: 999px;
				background: var(--brand-orange);
				box-shadow: 0 0 8px 0 color-mix(in oklab, var(--brand-orange) 80%, transparent);
				animation: orb-pulse 2.2s ease-in-out infinite;
			}

			@keyframes orb-pulse {
				0% { box-shadow: 0 0 0 0 color-mix(in oklab, var(--brand-orange) 70%, transparent); }
				70% { box-shadow: 0 0 0 7px color-mix(in oklab, var(--brand-orange) 0%, transparent); }
				100% { box-shadow: 0 0 0 0 color-mix(in oklab, var(--brand-orange) 0%, transparent); }
			}

			h1 {
				margin: 0;
				font-family: var(--font-display);
				font-weight: 800;
				font-size: clamp(2.1rem, calc(1.4rem + 3.4vw), 3.4rem);
				line-height: 1.03;
				letter-spacing: -0.02em;
				background: linear-gradient(
					165deg,
					var(--ink) 0%,
					color-mix(in oklab, var(--brand-300) 70%, white) 58%,
					var(--brand-300) 100%
				);
				-webkit-background-clip: text;
				background-clip: text;
				color: transparent;
			}

			.lede {
				margin: 0;
				max-width: 44ch;
				font-size: clamp(1rem, 0.95rem + 0.3vw, 1.15rem);
				line-height: 1.6;
				color: var(--ink-dim);
			}

			/* Indeterminate progress shimmer — signals "work in progress" */
			.progress {
				position: relative;
				width: min(20rem, 80%);
				height: 4px;
				margin: 0.4rem 0 0.2rem;
				border-radius: 999px;
				overflow: hidden;
				background: color-mix(in oklab, var(--brand) 22%, transparent);
			}

			.progress span {
				position: absolute;
				inset-block: 0;
				width: 40%;
				border-radius: inherit;
				background: linear-gradient(
					90deg,
					transparent,
					var(--brand-300),
					color-mix(in oklab, var(--brand-300) 60%, white),
					var(--brand-300),
					transparent
				);
				animation: progress-slide 1.8s ease-in-out infinite;
			}

			@keyframes progress-slide {
				0% { left: -45%; }
				100% { left: 105%; }
			}

			.signoff {
				margin: 0.5rem 0 0;
				font-size: 0.85rem;
				color: color-mix(in oklab, var(--ink-dim) 80%, transparent);
			}

			/* ---- Respect reduced-motion: hold everything still ---- */
			@media (prefers-reduced-motion: reduce) {
				.lava-blob,
				.mark,
				.kicker::before,
				.progress span,
				.panel {
					animation: none !important;
				}
			}
		</style>
	</body>
</html>
