    "@angular/cli": "21.2.16",
    "@angular/compiler-cli": "21.2.17",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4.2.4",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "dotenv": "17.4.2",
    "fast-check": "4.7.0",
    "jsdom": "29.1.0",
