    "@angular/platform-browser": "21.2.17",
    "@angular/router": "21.2.17",
    "@ctrl/ngx-emoji-mart": "9.3.0",
    "@microsoft/fetch-event-source": "2.0.1",
    "@ng-icons/core": "33.2.2",
    "@ng-icons/heroicons": "33.2.2",
    "chart.js": "4.5.1",
    "clipboard": "2.0.11",
    "katex": "0.16.45",
    "marked": "17.0.6",
    "mermaid": "11.15.0",
    "ng2-charts": "10.0.0",
    "ngx-markdown": "21.2.0",
